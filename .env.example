# Required — Render Postgres (External URL on your laptop; Internal on Render web service)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DB?sslmode=require

# Auth.js — generate with: openssl rand -base64 32
AUTH_SECRET=

# Canonical URL of the app (local vs production)
AUTH_URL=http://localhost:3000

# Public site URL (Spotify OAuth redirect base)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Spotify — redirect URI in dashboard:
#   http://localhost:3000/api/auth/spotify/callback
#   https://your-app.onrender.com/api/auth/spotify/callback
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
