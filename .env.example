# Required — full Postgres URL (username + password + host + database name)
# Example: postgresql://myuser:mypassword@ep-cool-123.us-east-2.aws.neon.tech/neondb?sslmode=require
# If your DB password contains @ # / : or spaces, URL-encode it (e.g. p@ss → p%40ss)
# Important: use only ONE DATABASE_URL line in .env.local — duplicate keys often pick the first.
DATABASE_URL=postgresql://USERNAME:PASSWORD@HOST:5432/DATABASE?sslmode=require

# Auth.js — generate with: openssl rand -base64 32
AUTH_SECRET=

# Canonical URL of the app (Auth.js). Must match the URL users open in the browser.
# Production: https://your-domain.com (no trailing slash)
AUTH_URL=http://localhost:3000

# Public site URL — same origin as AUTH_URL for OAuth redirects and client-side links.
# Production: https://your-domain.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Production checklist (see docs/ROADMAP.md Phase A):
# - Set AUTH_URL and NEXT_PUBLIC_SITE_URL to the live origin
# - Register the same origin in Spotify app Redirect URIs + Google/GitHub if used
# - Run: npm run db:push on the production DATABASE_URL

# ── OAuth sign-in (optional — add either or both) ─────────────────────────
# Google: see docs/GOOGLE_OAUTH.md — OAuth 2.0 Client (Web)
#   Redirect URI must be exactly: https://<your-origin>/api/auth/callback/google
#   e.g. http://localhost:3000/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# GitHub: https://github.com/settings/developers — OAuth App
#   Callback: http://localhost:3000/api/auth/callback/github
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Spotify (music linking — separate from login OAuth)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Google AI Studio — mood DJ (Gemini). Optional: without it, chat uses keyword presets only.
# https://aistudio.google.com/apikey
GEMINI_API_KEY=
#
# Optional: override Gemini model id (generativelanguage API).
# Default is gemini-2.0-flash.
GEMINI_MODEL=gemini-2.0-flash

# ── Sentry (error tracking) ───────────────────────────────────────────────
# https://sentry.io/
# DSN for browser-side error reporting
NEXT_PUBLIC_SENTRY_DSN=""
# DSN for server-side error reporting
SENTRY_DSN=""
# Auth token for uploading source maps during build. Required for source map uploads.
# Create at: https://<your-org>.sentry.io/settings/auth-tokens/
SENTRY_AUTH_TOKEN=""
# Sentry organization slug
SENTRY_ORG=""
# Sentry project slug
SENTRY_PROJECT=""
